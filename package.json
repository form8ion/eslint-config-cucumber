{
  "name": "@form8ion/eslint-config-cucumber",
  "description": "Shareable config for ESLint for Cucumber.js tests",
  "license": "MIT",
  "version": "0.0.0-semantically-released",
  "type": "commonjs",
  "author": "Matt Travi <npm@travi.org> (https://matt.travi.org/)",
  "repository": "form8ion/eslint-config-cucumber",
  "bugs": "https://github.com/form8ion/eslint-config-cucumber/issues",
  "homepage": "https://npm.im/@form8ion/eslint-config-cucumber",
  "scripts": {
    "test": "npm-run-all --print-label --parallel lint:*",
    "lint:js": "eslint . --cache",
    "lint:md": "remark . --frail",
    "lint:sensitive": "ban",
    "prepare": "husky install",
    "lint:publish": "publint --strict",
    "lint:js:fix": "run-s 'lint:js -- --fix'",
    "lint:lockfile": "lockfile-lint"
  },
  "files": [
    "index.js"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "packageManager": "npm@11.15.0+sha512.fa4d2d93b9519e93143e70bb913b94ff2ad5fe69c5a0f84943be557cbb59e9fc1bcce55768fb1313f225f4f9f50c78b8f366f2332aa41effd7b10efa98d8d72f",
  "dependencies": {
    "eslint-plugin-cucumber": "2.0.0"
  },
  "devDependencies": {
    "@form8ion/commitlint-config": "2.0.15",
    "@form8ion/eslint-config": "7.0.18",
    "@form8ion/remark-lint-preset": "6.0.7",
    "ban-sensitive-files": "1.10.11",
    "cz-conventional-changelog": "3.3.0",
    "husky": "9.1.7",
    "lockfile-lint": "5.0.0",
    "npm-run-all2": "9.0.0",
    "publint": "0.3.21",
    "remark-cli": "12.0.1"
  }
}
